# Loopr is local-first. With Ollama running you need none of these.
# Copy to .env and fill in only what you want.

# Local backend (default)
LOOPR_MODEL=qwen2.5:14b
OLLAMA_HOST=http://localhost:11434

# Pin a provider: ollama | openai | anthropic | auto (default)
# LOOPR_PROVIDER=auto

# Optional cloud fallbacks
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LOOPR_OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# LOOPR_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
